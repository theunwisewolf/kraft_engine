Shader Basic2D
{
    Layout
    {
        // Vertex layouts
        Vertex Main
        {
            Binding     0 32 vertex
            Attribute   float2 Position 0 0 0
            Attribute   float2 UV 0 1 12
            Attribute   float4 Color 0 2 20
        }

        UniformBuffer GlobalUniformBuffer
        {
            mat4   Projection;
            mat4   View;
            float3 LightPosition;
            float4 LightColor;
            float3 CameraPosition;
        }

        // Our Material Data
        StorageBuffer MaterialData
        {
            float4  DiffuseColor;
            texID   DiffuseTexture;
        }

        // List of local Resources: Uniform buffers, samplers, etc
        local Resource LocalResources
        {
            StorageBuffer MaterialData           Stage(Fragment) Set(0) Binding(1);
        }

        global Resource GlobalResources
        {
            UniformBuffer GlobalUniformBuffer    Stage(Fragment) Set(0) Binding(0);
        }

        // Constant buffers/Push constants
        ConstantBuffer Main
        {
            mat4    Model           Stage(Vertex);
        }
    }

    GLSL ToScreen
    {
        #version 450

        #extension GL_GOOGLE_include_directive: require

        #include "includes/kraft_shader_includes.h"
        #define KRAFT_VERTEX_REF_TYPE Vertex2DRef
        #include "includes/common.glsl"
        #undef KRAFT_VERTEX_REF_TYPE

        struct MeshMaterial
        {
            vec4  DiffuseColor;
            uint  DiffuseTexture;
            uint  _unused0;
            uint  _unused1;
            uint  _unused2;
            vec4  _unused3;
            vec4  _unused4;
        };

        layout (set = 0, binding = 2) readonly buffer GlobalMaterialData
        {
            MeshMaterial Materials[];
        };

        #if defined VERTEX

        // Output from the vertex shader to the fragment shader
        layout(location = 0) out struct DataTransferObject 
        {
            vec2 UV;
        } outDTO;

        void main()
        {
            Vertex2D vertex = vertices[gl_VertexIndex];
            outDTO.UV = vertex.uv;
            gl_Position = globalState.ViewProjection * variableState.Model * vec4(vertex.position, 0.0, 1.0);
        }

        #endif // VERTEX

        #if defined FRAGMENT

        precision highp float;

        layout (location = 0) in struct DataTransferObject 
        {
            vec2 UV;
        } inDTO;

        // Outputs
        layout (location = 0) out vec4 outColor;

        void main() 
        {
            // vec3 iResolution = vec3(2560.0, 1080.0, 1.0);
            // vec2 uv = gl_FragCoord.xy/iResolution.xy;
            // outColor = effect(iResolution.xyz, gl_FragCoord.xy);
            // outColor = vec4(inDTO.UV.x, inDTO.UV.y, 1.0, 1.0);
            MeshMaterial Material = Materials[variableState.MaterialIdx];
            outColor = Material.DiffuseColor * SampleTexture(Material.DiffuseTexture, inDTO.UV);
            // outColor = Material.DiffuseColor;
            // outColor = vec4(1.0, 0.0, 0.0, 1.0);
        }

        #endif // FRAGMENT
    }

    RenderState
    {
        State Default
        {       
            Cull            Off
            ZTest           Never
            ZWrite          Off
            Blend           SrcAlpha OneMinusSrcAlpha, SrcAlpha OneMinusSrcAlpha
            BlendOp         Add, Add
            PolygonMode     Fill
            LineWidth       1.0   
        }
    }

    Variant ToScreen
    {
        RenderState     Default
        VertexLayout    Main
        Resources       LocalResources
        ConstantBuffer  Main
        VertexShader    ToScreen
        FragmentShader  ToScreen
    }
}